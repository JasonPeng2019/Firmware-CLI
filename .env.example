# Copy to .env and edit for your machine. .env is gitignored and auto-loaded
# by the MCP server plus the Phase A host scripts when present.
# Both values are optional — omit them to let pyOCD auto-detect a single
# attached probe and target where possible.

# Whole or partial probe serial / unique ID (see `uv run pyocd list`).
PYOCD_PROBE_UID=

# Target type override, e.g. stm32f407vg, nrf52833.
PYOCD_TARGET=

# Turnkey brain provider selection.
# Valid values:
#   openai-api   -> native OpenAI Responses API
#   anthropic-api -> native Anthropic Messages API
#   codex-cli    -> local Codex CLI (subscription or API-key auth managed by Codex)
#   claude-cli   -> local Claude Code CLI (subscription or API-key auth managed by Claude)
PYOCD_TURNKEY_PROVIDER=openai-api

# Shared explicit model override for any provider path that supports or requires it.
PYOCD_TURNKEY_MODEL=

# Native API credentials.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
