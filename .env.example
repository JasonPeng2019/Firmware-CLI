# Copy to .env and edit for your machine. .env is gitignored and auto-loaded
# by the MCP server plus the Phase A host scripts when present.
# Both values are optional — omit them to let pyOCD auto-detect a single
# attached probe and target where possible.

# Whole or partial probe serial / unique ID (see `uv run pyocd list`).
PYOCD_PROBE_UID=

# Target type override, e.g. stm32f407vg, nrf52840.
PYOCD_TARGET=
