# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
/build/
/dist/

# --- Virtual environment (generated by `uv sync` — never commit) ---
.venv/

# NOTE: uv.lock IS committed (reproducible installs) — do not ignore it.
# NOTE: .python-version IS committed (pins the interpreter) — do not ignore it.

# --- Local overrides / secrets ---
.env
.env.*
!.env.example

# Per-developer pyOCD overrides (commit a shared pyocd.yaml; ignore the local one)
pyocd.local.yaml

# --- Tooling caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# --- OS / editor ---
.DS_Store
*.swp
.idea/
.vscode/
.vsix